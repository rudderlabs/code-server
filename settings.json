{
  "security.workspace.trust.enabled": false,
  "workbench.sideBar.location": "left",
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.colorCustomizations": {
    "sideBar.background": "#e9ebec",
    "sideBarSectionHeader.background": "#e9ebec",
    "editorGroupHeader.tabsBackground": "#e9ebec",
    "editorGroup.border": "#c0c0c0"
  },
  "terminal.integrated.defaultProfile.linux": "lshell",
  "terminal.integrated.profiles.linux": {
    "lshell": {
      "path": "/usr/local/bin/lshell"
    },
    "bash": null,
    "zsh": null,
    "sh": null,
    "dash": null,
    "fish": null,
    "csh": null,
    "ksh": null
  },
  "files.exclude": {
    "/etc/**": true,
    "/usr/**": true,
    "/var/**": true,
    "/opt/**": true,
    "/root/**": true,
    "/srv/**": true,
    "/run/**": true,
    "/boot/**": true,
    "/lib/**": true,
    "/sbin/**": true,
    "/bin/**": true,
    "/proc/**": true,
    "/sys/**": true,
    "/dev/**": true,
    "/mnt/**": true,
    "/media/**": true
  },
  "search.exclude": {
    "/etc/**": true,
    "/usr/**": true,
    "/var/**": true,
    "/opt/**": true,
    "/root/**": true,
    "/srv/**": true,
    "/run/**": true,
    "/boot/**": true,
    "/lib/**": true,
    "/sbin/**": true,
    "/bin/**": true,
    "/proc/**": true,
    "/sys/**": true,
    "/dev/**": true,
    "/mnt/**": true,
    "/media/**": true
  }
}
