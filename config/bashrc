# Simple prompt (username only)
PS1='\u\$ '

# Basic aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Source custom aliases if exists
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Source local environment if exists
if [ -f "$HOME/.local/bin/env" ]; then
    . "$HOME/.local/bin/env"
fi
