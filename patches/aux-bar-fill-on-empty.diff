+/* eslint-disable header/header */
+/*---------------------------------------------------------------------------------------------
+ *  code-server: PRO-5561 expand AuxiliaryBar to fill the editor area whenever there
+ *  are zero editor tabs AND the auxiliary bar (which hosts the Rudder AI panel) is
+ *  visible.
+ *
+ *  Trigger: any state where `editorService.count === 0` AND aux bar is visible.
+ *  This covers BOTH the transition case (user opens then closes all tabs in a
+ *  session) AND the initial-paint case (workspace restores with no tabs, e.g. a
+ *  fresh workspace OR a reload after the user previously closed everything). An
+ *  earlier revision of this contribution only fired on the transition and left
+ *  the watermark visible on cold-start-empty; reported as a bug -- on dev, after
+ *  closing all tabs the watermark would re-appear on the next page load.
+ *
+ *  Implementation: call the patched
+ *    setAuxiliaryBarMaximized(true, { keepSideBar: true })
+ *  so VS Code's own grid hands the editor + panel space to the AuxiliaryBar while
+ *  the left sidebar stays put. When an editor re-opens, VS Code's own
+ *  `setEditorHidden(false)` path auto-unmaximizes via `layout.ts:1780`, so we do
+ *  not need to do anything on the return trip.
+ *
+ *  The check is deferred via `queueMicrotask`: `onDidEditorsChange` fires during
+ *  the close transition, before `IEditorService.count` is updated, so reading the
+ *  count synchronously yields the pre-close value. Deferring to the next
+ *  microtask gives the service time to settle. Multiple bursty events in the same
+ *  tick (a single openEditor fires three onDidEditorsChange in one tick) collapse
+ *  into a single update via `updateScheduled`.
+ *
+ *  Registered at `WorkbenchPhase.AfterRestored` (earlier than `Eventually`) so the
+ *  initial-paint takeover fires as close to grid layout as possible, minimising
+ *  the visible flash of the default empty-editor watermark on cold-start-empty.
+ *
+ *  Matches the Figma "All tabs closed" state at node 108:1233.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { IWorkbenchContribution, WorkbenchPhase, registerWorkbenchContribution2 } from '../../../common/contributions.js';
+import { IEditorService } from '../../../services/editor/common/editorService.js';
+import { IWorkbenchLayoutService, Parts } from '../../../services/layout/browser/layoutService.js';
+
+class AuxBarExpandOnEmptyContribution extends Disposable implements IWorkbenchContribution {
+
+	private updateScheduled = false;
+
+	constructor(
+		@IEditorService private readonly editorService: IEditorService,
+		@IWorkbenchLayoutService private readonly layoutService: IWorkbenchLayoutService,
+	) {
+		super();
+		this._register(this.editorService.onDidEditorsChange(() => this.scheduleUpdate()));
+		// Initial-paint check: if the workbench restored with zero editors AND the
+		// aux bar is visible, fire the takeover immediately. Without this the cold-
+		// start case (no tabs to restore from previous session) leaves the watermark
+		// visible.
+		this.scheduleUpdate();
+	}
+
+	private scheduleUpdate(): void {
+		if (this.updateScheduled) {
+			return;
+		}
+		this.updateScheduled = true;
+		queueMicrotask(() => {
+			this.updateScheduled = false;
+			this.update();
+		});
+	}
+
+	private update(): void {
+		if (!this.layoutService.isVisible(Parts.AUXILIARYBAR_PART)) {
+			// User hid the auxiliary bar entirely; do not force it open.
+			return;
+		}
+		if (this.editorService.count > 0) {
+			// Editors are open -- editor part owns the layout. If we previously
+			// maximised the aux bar, VS Code's own setEditorHidden(false) path has
+			// already auto-unmaximised it (layout.ts:1780), so nothing to do here.
+			return;
+		}
+		if (!this.layoutService.isAuxiliaryBarMaximized()) {
+			this.layoutService.setAuxiliaryBarMaximized(true, { keepSideBar: true });
+		}
+	}
+}
+
+registerWorkbenchContribution2('workbench.contrib.codeServerProfiles.auxBarExpandOnEmpty', AuxBarExpandOnEmptyContribution, WorkbenchPhase.AfterRestored);
