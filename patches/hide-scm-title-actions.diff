Hide Source Control title bar actions

Suppress the commit, refresh, and other action icons that appear in the
SOURCE CONTROL header bar. This overrides the menuActions getter in
SCMViewPaneContainer to return undefined, which prevents PaneComposite
from populating the title toolbar with any actions.

Index: code-server/lib/vscode/src/vs/workbench/contrib/scm/browser/scmViewPaneContainer.ts
===================================================================
--- code-server.orig/lib/vscode/src/vs/workbench/contrib/scm/browser/scmViewPaneContainer.ts
+++ code-server/lib/vscode/src/vs/workbench/contrib/scm/browser/scmViewPaneContainer.ts
@@ -39,8 +39,13 @@
 	override create(parent: HTMLElement): void {
 		super.create(parent);
 		parent.classList.add('scm-viewlet');
 	}
 
+	// code-server: suppress SCM title bar actions (PRO-5298)
+	override get menuActions() {
+		return undefined;
+	}
+
 	override getOptimalWidth(): number {
 		return 400;
 	}
