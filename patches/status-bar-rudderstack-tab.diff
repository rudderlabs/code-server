+/* eslint-disable header/header */
+/*---------------------------------------------------------------------------------------------
+ *  code-server: PRO-5528 RudderStack tab status bar entry.
+ *  Renders a non-clickable label on the right edge of the status bar so
+ *  the IDE footer matches the Figma design at
+ *  https://www.figma.com/design/SDpW683dzIqtXeGsAyQqyt/Profiles-%7C-Feb-26th-2026?node-id=101-3202
+ *--------------------------------------------------------------------------------------------*/
+
+import { Disposable, MutableDisposable } from '../../../../base/common/lifecycle.js';
+import { localize } from '../../../../nls.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { IWorkbenchContribution, IWorkbenchContributionsRegistry, Extensions as WorkbenchExtensions } from '../../../common/contributions.js';
+import { LifecyclePhase } from '../../../services/lifecycle/common/lifecycle.js';
+import { IStatusbarEntryAccessor, IStatusbarService, StatusbarAlignment } from '../../../services/statusbar/browser/statusbar.js';
+
+// PRO-5528: placeholder copy; pending design confirmation. Once Figma
+// freezes the final label, swap this nls.localize key with the real one.
+const RUDDERSTACK_TAB_LABEL = localize('codeServer.rudderstackTab', "RudderStack tab");
+
+// The notifications bell registers itself at Number.NEGATIVE_INFINITY so it
+// is always last. We use a small finite negative number so we land just to
+// the left of the bell but right of every other RIGHT-aligned entry that
+// uses a positive priority (e.g. the editor-status entries at ~100).
+const RUDDERSTACK_TAB_PRIORITY = -100;
+
+class RudderstackTabStatusBarContribution extends Disposable implements IWorkbenchContribution {
+
+	static readonly ID = 'workbench.contrib.codeServerProfiles.rudderstackTab';
+
+	private readonly entry = this._register(new MutableDisposable<IStatusbarEntryAccessor>());
+
+	constructor(
+		@IStatusbarService private readonly statusbarService: IStatusbarService,
+	) {
+		super();
+
+		this.entry.value = this.statusbarService.addEntry(
+			{
+				name: RUDDERSTACK_TAB_LABEL,
+				text: RUDDERSTACK_TAB_LABEL,
+				ariaLabel: RUDDERSTACK_TAB_LABEL,
+				tooltip: RUDDERSTACK_TAB_LABEL,
+			},
+			'codeServerProfiles.rudderstackTab',
+			StatusbarAlignment.RIGHT,
+			RUDDERSTACK_TAB_PRIORITY,
+		);
+	}
+}
+
+Registry.as<IWorkbenchContributionsRegistry>(WorkbenchExtensions.Workbench)
+	.registerWorkbenchContribution(RudderstackTabStatusBarContribution, LifecyclePhase.Restored);
