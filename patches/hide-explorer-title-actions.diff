 }
+
+/* code-server: PRO-5559 hide the entire Explorer composite title row
+ * (the "EXPLORER" label and any remaining title-actions toolbar). The
+ * `.explorer-viewlet` class is added to the content area by
+ * ExplorerViewPaneContainer.create(); :has() lets us walk up to the
+ * sidebar composite and hide the sibling .composite.title element. */
+.monaco-workbench .part.sidebar:has(.explorer-viewlet) > .composite.title {
+	display: none !important;
+}
